# Alembic
alembic/versions/__pycache__/

# launchd — generated plists are machine-specific; only track the template
launchd/*.plist

# Production deploy artefacts — db snapshots and service logs
.backups/
backend*.log
scheduler*.log

# Cloudflare Tunnel — credentials contain secret tunnel token
.cloudflared/*.json
.cloudflared/config.yml
# Keep template and hostname hint
!.cloudflared/config.yml.template

# Node
node_modules/

# Admin SPA build output — generated by `npm run build` + copied into the
# backend image at docker build time (COPY . .). Never committed.
backend/static/admin/
